# Fastmail IMAP
set imap_user = "juanlu@fastmail.com"
set from = "juanlu@fastmail.com"
set real_name = "Juanlu Herrero"
set imap_pass = "`gpg --quiet --decrypt ~/.neomutt/fastmail_pass.gpg`"
set folder = "imaps://imap.fastmail.com/"
set spool_file = "imaps://imap.fastmail.com/INBOX"
set imap_check_subscribed = yes
set imap_idle = yes
set imap_check_subscribed = yes
set timeout = 60
set mail_check = 120

# Fastmail SMTP
set smtp_url = "smtp://juanlu@fastmail.com@smtp.fastmail.com:587/"
set smtp_pass = "`gpg --quiet --decrypt ~/.neomutt/fastmail_pass.gpg`"
set smtp_authenticators = "plain"

# General
set ssl_starttls = yes
set editor = "nvim"
set record = "imaps://imap.fastmail.com/Sent"
set copy = yes
set certificate_file = "~/.neomutt/certificates"
set ssl_force_tls = yes

# syntax highlighting
color body green default "^[+].*"
color body red default "^-.*"
color body cyan default "^@@.*"
color body brightyellow default "^diff.*"
color body brightyellow default "^index.*"
color body brightyellow default "^---.*"
color body brightyellow default "^[+][+][+].*"
color body magenta default "^commit [0-9a-f]+"
color body blue default "^(Author|Date):.*"
color body brightblue default "^Subject:.*"
color body brightcyan default "^[A-Za-z-]+-by:.*"
color body brightcyan default "^Cc:.*"

# Readability
set wrap = 0
set pager_stop = yes
set pager_index_lines = 10
set sort = threads
set sort_aux = last-date-received
set index_format = "%4C %Z %{%b %d} %-20.20L %s"

# Sidebar
set sidebar_visible = yes
set sidebar_width = 25
set sidebar_format = "%B%?F? [%F]?%* %?N?%N/?%S"
 
# Vim-like navigation
bind pager j next-line
bind pager k previous-line
bind pager g top
bind pager G bottom

# Platform-specific overrides
source `uname -s | grep -q Darwin && echo ~/.neomutt/macos.rc || echo ~/.neomutt/linux.rc`
